@model WebProgProjc.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
}

<div class="auth-container">
    <div class="auth-card login-card">
        <div class="auth-header">
            <div class="auth-icon">
                <i class="fas fa-sign-in-alt"></i>
            </div>
            <h2>@ViewData["Title"]</h2>
            <p>Hesabınıza giriş yapın</p>
        </div>
        
        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <div class="form-floating mb-4">
                <input asp-for="Email" class="form-control form-control-lg" placeholder="email@example.com" />
                <label asp-for="Email" class="control-label">
                    <i class="fas fa-envelope"></i> Email Adresi
                </label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control form-control-lg" placeholder="Password" />
                <label asp-for="Password" class="control-label">
                    <i class="fas fa-lock"></i> Şifre
                </label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            
            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" id="rememberCheck" />
                <label asp-for="RememberMe" class="form-check-label" for="rememberCheck">
                    <i class="fas fa-check"></i> Beni hatırla
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-lg w-100 auth-btn">
                <i class="fas fa-sign-in-alt"></i> Giriş Yap
            </button>
        </form>
        
        <div class="auth-footer">
            <p>Hesabınız yok mu? <a asp-controller="Account" asp-action="Register" class="auth-link">Kayıt olun</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
