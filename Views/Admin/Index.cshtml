@model IEnumerable<WebProgProjc.Models.Reservation>
@{
    ViewData["Title"] = "Admin Paneli";
    var rooms = ViewBag.Rooms as IEnumerable<WebProgProjc.Models.Room> ?? new List<WebProgProjc.Models.Room>();
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Admin Paneli</h2>

    <!-- İstatistik Kartları -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-4">
                    <div class="stat-icon mb-2">
                        <i class="fas fa-calendar-alt fa-2x text-primary"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalReservations</h3>
                    <p class="text-muted small mb-0">Toplam Rezervasyon</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-4">
                    <div class="stat-icon mb-2">
                        <i class="fas fa-check-circle fa-2x text-success"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@ViewBag.ActiveReservations</h3>
                    <p class="text-muted small mb-0">Aktif Rezervasyon</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-4">
                    <div class="stat-icon mb-2">
                        <i class="fas fa-door-open fa-2x text-warning"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalRooms</h3>
                    <p class="text-muted small mb-0">Aktif Oda</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center border-0 shadow-sm h-100">
                <div class="card-body py-4">
                    <div class="stat-icon mb-2">
                        <i class="fas fa-calendar-day fa-2x text-info"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@ViewBag.ThisMonthReservations</h3>
                    <p class="text-muted small mb-0">Bu Ay</p>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Oda Yönetimi -->
    <div class="card shadow-sm mb-5">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-door-open me-2"></i>Oda Yönetimi</h5>
            <a asp-controller="Room" asp-action="Create" class="btn btn-sm btn-success">
                <i class="fas fa-plus me-1"></i> Yeni Oda
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Oda Adı</th>
                            <th class="d-none d-md-table-cell">Açıklama</th>
                            <th class="d-none d-sm-table-cell">Kapasite</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in rooms)
                        {
                            <tr>
                                <td class="fw-semibold">@room.Name</td>
                                <td class="d-none d-md-table-cell text-muted">@room.Description</td>
                                <td class="d-none d-sm-table-cell">@room.Capacity kişi</td>
                                <td>
                                    @if (room.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Room" asp-action="Edit" asp-route-id="@room.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (room.IsActive)
                                    {
                                        <form asp-controller="Room" asp-action="Delete" asp-route-id="@room.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Bu odayı devre dışı bırakmak istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Tüm Rezervasyonlar -->
    <div class="card shadow-sm">
        <div class="card-header py-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-calendar-alt me-2"></i>Tüm Rezervasyonlar</h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-muted">Henüz rezervasyon bulunmamaktadır.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="d-none d-md-table-cell">Kullanıcı</th>
                                <th>Oda</th>
                                <th>Başlangıç</th>
                                <th class="d-none d-sm-table-cell">Bitiş</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td class="d-none d-md-table-cell small">@r.User.Email</td>
                                    <td class="fw-semibold">@r.Room.Name</td>
                                    <td>@r.StartTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="d-none d-sm-table-cell">@r.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (r.IsCancelled)
                                        {
                                            <span class="badge bg-danger">İptal</span>
                                        }
                                        else if (r.EndTime < DateTime.UtcNow)
                                        {
                                            <span class="badge bg-secondary">Tamamlandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Aktif</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!r.IsCancelled && r.StartTime > DateTime.UtcNow)
                                        {
                                            <form asp-action="CancelReservation" asp-route-id="@r.Id" method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Bu rezervasyonu iptal etmek istediğinize emin misiniz?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fas fa-times me-1"></i>İptal Et
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
