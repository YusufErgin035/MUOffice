@model IEnumerable<WebProgProjc.Models.Reservation>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Hoş Geldiniz</h2>
        <a asp-controller="Room" asp-action="Index" class="btn btn-primary">
            <i class="fas fa-calendar-plus me-1"></i> Oda Rezerve Et
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h5 class="fw-semibold mb-3">Aktif Rezervasyonlarınız</h5>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Aktif rezervasyonunuz bulunmamaktadır.
            <a asp-controller="Room" asp-action="Index" class="alert-link">Oda rezerve edin.</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var r in Model)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="card-title fw-bold">@r.Room.Name</h6>
                            <p class="card-text mb-1">
                                <i class="fas fa-clock me-1 text-muted"></i>
                                @r.StartTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                — @r.EndTime.ToLocalTime().ToString("HH:mm")
                            </p>
                            <span class="badge bg-success">Aktif</span>
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <form asp-controller="Reservation" asp-action="Cancel" asp-route-id="@r.Id" method="post"
                                  onsubmit="return confirm('Rezervasyonu iptal etmek istediğinize emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-times me-1"></i>İptal Et
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-3">
            <a asp-controller="Reservation" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-history me-1"></i> Tüm Rezervasyon Geçmişi
            </a>
        </div>
    }
</div>
