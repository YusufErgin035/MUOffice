@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">
            <i class="fas fa-building"></i> MÜ Office
        </h1>
        <p class="hero-subtitle">Modern Ofis Alanlarını Keşfedin ve Rezervasyon Yapın</p>
        <p class="hero-description">
            Açık ofis alanlarını inceleyin ve ihtiyacınıza uygun çalışma ortamını rezerve edin.
        </p>
        @if (User.Identity.IsAuthenticated)
        {
            <div class="hero-buttons">
                <a href="#" class="btn btn-primary btn-lg hero-btn">
                    <i class="fas fa-search"></i> Ofisleri Keşfet
                </a>
                <a href="#" class="btn btn-outline-light btn-lg hero-btn">
                    <i class="fas fa-calendar"></i> Rezervasyonlarım
                </a>
            </div>
        }
        else
        {
            <div class="hero-buttons">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg hero-btn">
                    <i class="fas fa-sign-in-alt"></i> Giriş Yapın
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg hero-btn">
                    <i class="fas fa-user-plus"></i> Kayıt Olun
                </a>
            </div>
        }
    </div>
</div>

<!-- Features Section -->
<section class="features-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">
            <i class="fas fa-star"></i> Neden Biz?
        </h2>
        
        <div class="row g-4">
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-map-location-dot"></i>
                    </div>
                    <h5>Merkezi Konumlar</h5>
                    <p>Şehrin en iyi lokasyonlarında yer alan modern ofis alanları.</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-wifi"></i>
                    </div>
                    <h5>Tam Donanımlı</h5>
                    <p>Yüksek hızlı internet, çeşitli kütüphaneler ve meeting odaları.</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h5>Kolay Rezervasyon</h5>
                    <p>Basit ve hızlı rezervasyon sistemi ile istediğiniz zamanı seçin.</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5>İş Ağı Kurun</h5>
                    <p>Diğer profesyonellerle tanışın ve işbirliği fırsatları yaratın.</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h5>Rahat Ortam</h5>
                    <p>Sakin, produktif ve yaratıcılığı teşvik eden çalışma alanları.</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h5>7/24 Destek</h5>
                    <p>Her zaman size yardımcı olmaya hazır profesyonel destek ekibi.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section py-5">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-3">
                <div class="stat-box">
                    <h3 class="stat-number">150+</h3>
                    <p>Ofis Alanı</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-box">
                    <h3 class="stat-number">2000+</h3>
                    <p>Mutlu Kullanıcı</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-box">
                    <h3 class="stat-number">50+</h3>
                    <p>Şehir</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-box">
                    <h3 class="stat-number">98%</h3>
                    <p>Memnuniyet Oranı</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5">
    <div class="container">
        <div class="cta-box text-center">
            <h2>Hemen Başlamaya Hazır mısınız?</h2>
            <p>Giriş yapın veya kaydolun ve ofis alanlarını keşfetmeye başlayın.</p>
            @if (!User.Identity.IsAuthenticated)
            {
                <div class="cta-buttons">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                        <i class="fas fa-user-plus"></i> Ücretsiz Kaydol
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-sign-in-alt"></i> Giriş Yap
                    </a>
                </div>
            }
        </div>
    </div>
</section>
