@model IEnumerable<WebProgProjc.Models.Reservation>
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Rezervasyonlarım</h2>
        <a asp-controller="Room" asp-action="Index" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Yeni Rezervasyon
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Henüz rezervasyonunuz bulunmamaktadır.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Oda</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.Room.Name</td>
                            <td>@r.StartTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@r.EndTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (r.IsCancelled)
                                {
                                    <span class="badge bg-danger">İptal Edildi</span>
                                }
                                else if (r.EndTime < DateTime.UtcNow)
                                {
                                    <span class="badge bg-secondary">Tamamlandı</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                            </td>
                            <td>
                                @if (!r.IsCancelled && r.StartTime > DateTime.UtcNow)
                                {
                                    <form asp-action="Cancel" asp-route-id="@r.Id" method="post"
                                          onsubmit="return confirm('Rezervasyonu iptal etmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-times me-1"></i>İptal Et
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
