@model WebProgProjc.Models.ViewModels.ReservationViewModel
@{
    ViewData["Title"] = "Rezervasyon Yap";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="card-title fw-bold mb-4">
                        <i class="fas fa-calendar-plus me-2"></i>Rezervasyon Yap
                    </h4>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger d-none" id="validationSummary"></div>

                        <div class="mb-3">
                            <label asp-for="RoomId" class="form-label fw-semibold">Oda</label>
                            <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="form-select">
                                <option value="">-- Oda Seçin --</option>
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StartTime" class="form-label fw-semibold">Başlangıç Saati</label>
                            <input asp-for="StartTime" type="datetime-local" class="form-control"
                                   value="@DateTime.Now.AddHours(1).ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EndTime" class="form-label fw-semibold">Bitiş Saati</label>
                            <input asp-for="EndTime" type="datetime-local" class="form-control"
                                   value="@DateTime.Now.AddHours(2).ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check me-1"></i> Rezervasyonu Onayla
                            </button>
                            <a asp-controller="Room" asp-action="Index" class="btn btn-outline-secondary">Geri</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const summary = document.querySelector('[data-valmsg-summary]') ?? document.getElementById('validationSummary');
        if (summary && summary.querySelectorAll('li').length > 0) summary.classList.remove('d-none');
    </script>
}
