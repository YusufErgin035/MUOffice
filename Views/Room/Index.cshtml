@model IEnumerable<WebProgProjc.Models.Room>
@{
    ViewData["Title"] = "Odalar";
}

<div class="container py-5">
    <h2 class="mb-4 fw-bold">Müsait Odalar</h2>

    <form method="get" class="row g-2 mb-4">
        <div class="col-12 col-sm-6 col-md-5">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                   placeholder="Oda adı veya açıklama ara..." />
        </div>
        <div class="col-8 col-sm-4 col-md-3">
            <input type="number" name="minCapacity" value="@ViewBag.MinCapacity" class="form-control"
                   placeholder="Min. kapasite" min="1" />
        </div>
        <div class="col-4 col-sm-2 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">
                <i class="fas fa-search"></i>
            </button>
            @if (ViewBag.Search != null || ViewBag.MinCapacity != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-times"></i>
                </a>
            }
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Şu an aktif oda bulunmamaktadır.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var room in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@room.Name</h5>
                            <p class="card-text text-muted">@room.Description</p>
                            <p class="card-text">
                                <i class="fas fa-users me-1"></i>
                                <strong>Kapasite:</strong> @room.Capacity kişi
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Reservation" asp-action="Create" asp-route-roomId="@room.Id"
                                   class="btn btn-primary w-100">
                                    <i class="fas fa-calendar-plus me-1"></i> Rezervasyon Yap
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100">
                                    Rezervasyon için giriş yapın
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
